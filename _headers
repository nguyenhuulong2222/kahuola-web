/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://unpkg.com https://cdnjs.cloudflare.com https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://unpkg.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: blob: https://api.maptiler.com; connect-src 'self' https://api.maptiler.com https://kahuola.org https://unpkg.com; worker-src 'self' blob:; child-src 'self' blob:;
  Cache-Control: public, max-age=60

/index.html
  Cache-Control: public, max-age=60

/portal
  Cache-Control: public, max-age=60

/portal.html
  Cache-Control: public, max-age=60

/privacy
  Cache-Control: public, max-age=3600

/privacy.html
  Cache-Control: public, max-age=3600

/support
  Cache-Control: public, max-age=3600

/support.html
  Cache-Control: public, max-age=3600

/styles.css
  Cache-Control: public, max-age=31536000, immutable

/layers.config.js
  Cache-Control: public, max-age=31536000, immutable

/assets/*
  Cache-Control: public, max-age=31536000, immutable
